{
  "name": "codelv",
  "productName": "CodeLv",
  "version": "0.1.0",
  "description": "開発者の努力をRPG風に可視化するデスクトップアプリ",
  "author": "hotate0606",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win --x64",
    "release": "npm version patch && git push --follow-tags"
  },
  "build": {
    "appId": "com.hotate0606.codelv",
    "productName": "CodeLv",
    "artifactName": "${productName}-Setup.${ext}",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "node-machine-id": "^1.1.12"
  },
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1"
  }
}
